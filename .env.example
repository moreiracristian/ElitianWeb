# ══════════════════════════════════════════════════════════════════════════════
# ElitianWeb — Variables de entorno
# Copiá este archivo como .env y completá los valores reales.
# NUNCA subas .env a git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
# Generá uno nuevo con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CAMBIAR_POR_CLAVE_SEGURA

# False siempre en producción
DEBUG=False

# Hosts separados por coma
ALLOWED_HOSTS=elitian.com.ar,www.elitian.com.ar

# Origins del frontend separados por coma
CORS_ALLOWED_ORIGINS=https://elitian.com.ar,https://www.elitian.com.ar

# ── Base de datos PostgreSQL ───────────────────────────────────────────────────
DB_NAME=elitiandb
DB_USER=postgres
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
DB_HOST=db
DB_PORT=5432

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL pública del frontend (sin barra al final)
SITE_URL=https://elitian.com.ar

# URL pública del backend — la usa MercadoPago para el webhook
WEBHOOK_URL=https://api.elitian.com.ar

# ── Sentry — error tracking ───────────────────────────────────────────────────
# Registrate en sentry.io → New Project → Django → copiá el DSN
# Si está vacío Sentry no se activa
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# ── MercadoPago ───────────────────────────────────────────────────────────────
# Obtenelos en: https://www.mercadopago.com.ar/developers/panel/app
# Usar credenciales TEST para pruebas, PROD para pagos reales
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=tu_webhook_secret

# ── Email SMTP ────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Gmail: activar 2FA y generar App Password en myaccount.google.com/apppasswords
EMAIL_HOST_USER=tu-cuenta@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=Elitian <hola@elitian.com.ar>
